{
  "name": "assembly",
  "version": "0.2.0",
  "description": "Agent factory lines — folder-driven agent workflows",
  "license": "MIT",
  "type": "module",
  "workspaces": ["web"],
  "bin": {
    "assembly": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --outdir dist --target node",
    "dashboard:web": "cd web && bun run dev",
    "build:web": "cd web && bun run build",
    "prepublishOnly": "bun run build:web",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dashboard:web": "cd web && bun run dev",
    "build:web": "cd web && bun run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "gray-matter": "^4.0.3",
    "morphdom": "^2.7.4",
    "yaml": "^2.7.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^14.12.0",
    "@types/bun": "latest",
    "eslint": "^10.4.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "happy-dom": "^14.12.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.15.0"
  }
}
