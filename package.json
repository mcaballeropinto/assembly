{
  "name": "assembly",
  "version": "0.2.0",
  "description": "Agent factory lines — folder-driven agent workflows",
  "license": "MIT",
  "type": "module",
  "workspaces": ["web"],
  "bin": {
    "assembly": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --outdir dist --target node",
    "dashboard:web": "cd web && bun run dev",
    "build:web:assets": "cd web && bunx vite build",
    "build:web": "cd web && bun run build",
    "check:dashboard:release": "bun run scripts/check-dashboard-release.ts",
    "release:dashboard": "bun run build:web && bun run check:dashboard:release",
    "prepublishOnly": "bun run build:web",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "gray-matter": "^4.0.3",
    "yaml": "^2.7.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^14.12.0",
    "@types/bun": "latest",
    "eslint": "^10.4.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "happy-dom": "^14.12.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.15.0"
  }
}
