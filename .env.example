# Copy to .env (or set in your shell) before running assembly.

# === Anthropic API ===
# Required for the claude-code provider. Get one at https://console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-...

# === assembly-dev line (optional) ===
# Path to the cloned assembly repo root. Required ONLY if you run the
# `assembly-dev` line, which spawns Claude in a per-task git worktree.
# ASSEMBLY_REPO_ROOT=/path/to/assembly

# Override the default model used by assembly-dev's `develop` station.
# ASSEMBLY_DEV_MODEL=sonnet

# Systemd unit name for an external dashboard service. If unset, the deploy
# station skips the restart step entirely.
# ASSEMBLY_DASHBOARD_SERVICE=assembly-dashboard

# === repo-health-digest line (optional) ===
# Lifts the unauthenticated 60-req/hr GitHub API ceiling.
# GITHUB_TOKEN=ghp_...
